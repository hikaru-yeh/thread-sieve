# Copy to .env and fill in.

# catch.json path that the forked userscript writes to (File System Access API handle target).
CATCH_PATH=data/catch.json

# unsave.json path that classify_to_scribe_ai.py writes (and userscript polls).
UNSAVE_PATH=data/unsave.json

# markdown location. watch_pipeline.py runs `python app.py` here.
MARKDOWN_PATH=..\PROJECT_threads-to-note

# markdown output root. crawl-the-threads scans this tree after notes are written
# and appends ## 圖片文字 to matching markdown files.
# If unset, watch_pipeline.py tries THREADS_MARKDOWN_OUTPUT from MARKDOWN_PATH\.env.
MARKDOWN_OUTPUT_PATH=

# Path to the chrome-ws CLI (bundled with superpowers-chrome plugin).
# Find it under: ~/.claude/plugins/cache/superpowers-marketplace/superpowers-chrome/<version>/skills/browsing/chrome-ws
CHROME_WS_PATH=

# (Optional) Path to threads-scriber.user.js source — only needed when running _rebuild_userscript.py.
THREADS_SCRIBER_PATH=..\threads-scriber\threads-scriber.user.js

# Gemini API key for classify_to_scribe_ai.py.
GEMINI_API_KEY=

# Gemini model used for classification.
CLASSIFIER_MODEL=gemini-2.5-flash

# Gemini Vision OCR for image-heavy markdown notes.
IMAGE_OCR_ENABLED=true
IMAGE_OCR_MODEL=gemini-2.5-flash
IMAGE_OCR_CATEGORIES=AI,Claude Code

# Watcher tuning.
DEBOUNCE_SECONDS=2.0
POLL_SECONDS=1.0
