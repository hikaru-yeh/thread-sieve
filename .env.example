# Copy to .env and fill in.

# Non-secret paths live in config.json under "paths".

# Gemini API key.
# Required for classification and (when image-ocr.backend=gemini) image OCR.
GEMINI_API_KEY=

# Gemini model used for classification.
CLASSIFIER_MODEL=gemini-2.5-flash

# Image OCR toggle and model. Trigger categories live in config.json.
IMAGE_OCR_ENABLED=true
IMAGE_OCR_MODEL=gemini-2.5-flash
